---
import PokemonCard from "./pokemonCard.astro";
import { pokemons } from "../data/pokemon";

const DISPLAY_LIMIT = 12;
const displayedPokemons = pokemons.slice(0, DISPLAY_LIMIT);
const hasMore = pokemons.length > DISPLAY_LIMIT;
---

<section class="py-20 bg-pokemon-lblue">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-4xl font-heading">Pokemon Collection</h2>
      <p class="text-gray-500 mt-3 font-body">Search your favorite Pokemon</p>
    </div>

    <div id="pokemonContainer" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {
        displayedPokemons.map((pokemon) => (
          <div class="pokemon-item" data-name={pokemon.name.toLowerCase()}>
            <PokemonCard pokemon={pokemon} />
          </div>
        ))
      }
    </div>

    <!-- Button View More: hanya tampil jika total pokemon > DISPLAY_LIMIT -->
    {
      hasMore && (
        <div class="flex justify-center mt-10">
          <a href="/pokedex" class="px-6 py-3 bg-pokemon-primer hover:bg-pokemon-hover text-pokemon-dblue font-semibold rounded-lg transition duration-300">
            View More
          </a>
        </div>
      )
    }
  </div>
</section>
