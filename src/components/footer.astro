---
const socialLinks = [
  {
    name: "Instagram",
    url: "#",
    icon: "instagram",
  },
  {
    name: "Pinterest",
    url: "#",
    icon: "pinterest",
  },
  {
    name: "X",
    url: "#",
    icon: "x",
  },
];
---

<footer class="relative bg-[#00364f] text-white py-10 md:py-12">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <!-- Title -->
    <h2 class="text-3xl md:text-4xl font-bold text-[#ffb633] mb-5">Pokemon World</h2>

    <!-- Description -->
    <p class="max-w-xl mx-auto text-sm md:text-base leading-relaxed text-gray-100">
      Pokemon World adalah website dummy yang dibuat untuk menampilkan koleksi Pokémon populer lengkap dengan fitur pencarian berdasarkan nama. Dibangun menggunakan Astro dan Tailwind CSS untuk latihan pengembangan frontend modern.
    </p>

    <!-- Social Media -->
    <div class="flex justify-center items-center gap-6 mt-8">
      {
        socialLinks.map((item) => (
          <a
            href={item.url}
            aria-label={item.name}
            class="
              text-white 
              hover:scale-110 
              transition
            "
          >
            {item.icon === "instagram" && (
              <svg width="25" height="25" viewBox="0 0 24 24" fill="currentColor">
                <path d="M7 2C4.2 2 2 4.2 2 7v10c0 2.8 2.2 5 5 5h10c2.8 0 5-2.2 5-5V7c0-2.8-2.2-5-5-5H7zm10 2c1.7 0 3 1.3 3 3v10c0 1.7-1.3 3-3 3H7c-1.7 0-3-1.3-3-3V7c0-1.7 1.3-3 3-3h10zm-5 3.5A4.5 4.5 0 1 0 16.5 12 4.5 4.5 0 0 0 12 7.5zm0 7.5a3 3 0 1 1 3-3 3 3 0 0 1-3 3zm5.2-8.8a1 1 0 1 0 1 1 1 1 0 0 0-1-1z" />
              </svg>
            )}

            {item.icon === "pinterest" && (
              <svg width="25" height="25" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2a10 10 0 0 0-3.7 19.3c-.1-1.6 0-3.5.4-5l1.1-4.6s-.3-.7-.3-1.7c0-1.6.9-2.8 2.1-2.8 1 0 1.5.7 1.5 1.7 0 1-.6 2.6-.9 4-.3 1.2.6 2.2 1.8 2.2 2.1 0 3.7-2.2 3.7-5.3 0-2.8-2-4.8-5-4.8-3.4 0-5.4 2.5-5.4 5.1 0 1 .4 2 .9 2.5.1.1.1.2.1.4l-.3 1.2c-.1.4-.4.5-.7.4-1.9-.9-3.1-3.5-3.1-5.6 0-4.6 3.3-8.8 9.6-8.8 5 0 8.9 3.6 8.9 8.4 0 5-3.1 9-7.4 9-1.4 0-2.7-.7-3.1-1.5l-.9 3.4c-.3 1.3-1 2.8-1.5 3.8A10 10 0 1 0 12 2z" />
              </svg>
            )}

            {item.icon === "x" && <span class="text-3xl font-light">𝕏</span>}
          </a>
        ))
      }
    </div>

    <!-- Divider -->
    <div class="border-t border-white/20 mt-8"></div>

    <!-- Copyright -->
    <p class="text-xs mt-5 text-gray-200">© 2026 Pokemon World. All Rights Reserved.</p>
  </div>

  <!-- Scroll Up Button -->
  <a href="#" class="absolute
      right-8
      bottom-16
      md:right-10
      flex
      flex-col
      items-center
      gap-2">
    <div class="w-11
        h-11
        rounded-full
        bg-[#ffb633]
        flex
        items-center
        justify-center
        text-white
        text-xl
        shadow-lg">↑</div>

    <span class="text-sm"> Scroll Up </span>
  </a>
</footer>
