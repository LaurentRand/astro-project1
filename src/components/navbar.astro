---
// Navbar.astro - Responsive Pokemon Navbar
// Mobile: hamburger + drawer | Desktop: horizontal nav
---

<header class="fixed top-0 left-0 w-full z-30 bg-white/20 backdrop-blur-md">
  <nav class="flex items-center justify-between w-full px-6 md:px-15 py-3 font-medium">
    <!-- Logo -->
    <a href="#" class="text-pokemon-red text-2xl font-brand z-50 relative">
      Pokemon<span class="text-pokemon-primer font-brand">GO</span>
    </a>

    <!-- Desktop Menu -->
    <ul class="hidden md:flex items-center gap-6 font-heading absolute left-1/2 -translate-x-1/2">
      <li class="text-pokemon-dblue hover:text-gray-400 transition-colors">
        <a href="/">Home</a>
      </li>
      <li class="text-pokemon-dblue hover:text-gray-400 transition-colors">
        <a href="/pokedex">Pokédex</a>
      </li>
    </ul>

    <!-- Hamburger Button (Mobile only) -->
    <button id="hamburger-btn" class="md:hidden z-50 relative flex flex-col justify-center items-center w-8 h-8 gap-1.5 cursor-pointer" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger-line block w-6 h-0.5 bg-pokemon-dblue rounded transition-all duration-300 ease-in-out"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-pokemon-dblue rounded transition-all duration-300 ease-in-out"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-pokemon-dblue rounded transition-all duration-300 ease-in-out"></span>
    </button>
  </nav>

  <!-- Mobile Drawer Menu -->
  <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out bg-pokemon-dblue/20 backdrop-blur-md">
    <ul class="flex flex-col font-heading px-6 pb-5 pt-2 gap-4 text-center">
      <li>
        <a href="/" class="block text-pokemon-dblue hover:text-gray-100 transition-colors text-lg mt-2 py-1"> Home </a>
      </li>
      <li class="w-full h-px bg-white/25" aria-hidden="true"></li>
      <li>
        <a href="/pokedex" class="block text-pokemon-dblue hover:text-gray-100 transition-colors text-lg py-1"> Pokédex </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("hamburger-btn") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLDivElement;
  const lines = btn.querySelectorAll<HTMLSpanElement>(".hamburger-line");

  let isOpen = false;

  // Fungsi utilitas untuk menutup menu (agar kode tidak berulang)
  function closeMenu() {
    isOpen = false;
    menu.style.maxHeight = "0";
    btn.setAttribute("aria-expanded", "false");
    lines[0].style.transform = "";
    lines[1].style.opacity = "";
    lines[2].style.transform = "";
    lines.forEach((line) => line.classList.replace("bg-white", "bg-pokemon-dblue"));
  }

  btn.addEventListener("click", () => {
    isOpen = !isOpen;
    btn.setAttribute("aria-expanded", String(isOpen));

    if (isOpen) {
      menu.style.maxHeight = menu.scrollHeight + "px";
      lines[0].style.transform = "translateY(8px) rotate(45deg)";
      lines[1].style.opacity = "0";
      lines[2].style.transform = "translateY(-8px) rotate(-45deg)";
      lines.forEach((line) => line.classList.replace("bg-pokemon-dblue", "bg-white"));
    } else {
      closeMenu();
    }
  });

  // Tutup menu saat link diklik (navigasi mobile)
  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      closeMenu();
    });
  });

  // PERUBAHAN UTAMA: Deteksi klik di luar area menu & tombol hamburger untuk menutup drawer
  document.addEventListener("click", (event) => {
    const target = event.target as Node;

    // Jika menu sedang terbuka, dan area yang diklik BUKAN bagian dari menu serta BUKAN dari tombol hamburger
    if (isOpen && !menu.contains(target) && !btn.contains(target)) {
      closeMenu();
    }
  });

  // Tutup menu saat resize ke desktop
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768 && isOpen) {
      closeMenu();
    }
  });
</script>
